          <mxGeometry x="36.99941176470588" y="1414.0017647058824" width="387" height="297" as="geometry" />
        </mxCell>
        <mxCell id="_BpPlqtfjkwMGcMm4Pci-40" value="Example: Tenemos el actor Cliente&amp;nbsp;&lt;div&gt;con el CU &quot;Consultar el inventario de la biblioteca&quot;,&lt;/div&gt;&lt;div&gt;ahora tenemos los actores &quot;Usuario regular&quot; y &quot;Visitante&quot;,&lt;/div&gt;&lt;div&gt;ambos heredan la funcionalidad/CU de actor &quot;Cliente&quot;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=15;" parent="1" vertex="1">
