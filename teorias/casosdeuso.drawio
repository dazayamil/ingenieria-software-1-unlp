        </mxCell>
        <mxCell id="_BpPlqtfjkwMGcMm4Pci-33" value="Teniendo el caso de uso A y caso de uso B,&amp;nbsp;&lt;div&gt;si CU B extiende de CU A,&lt;div&gt;entonces el cabezal de la fecla esta en el CU A,&amp;nbsp;&lt;/div&gt;&lt;div&gt;como&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;muestra en la imagen.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;Podemos tomar referencia, a lo que es gerencia en POO.&lt;/div&gt;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=15;" parent="1" vertex="1">
          <mxGeometry x="377.5" y="752" width="401" height="102" as="geometry" />
        </mxCell>
        <mxCell id="_BpPlqtfjkwMGcMm4Pci-34" value="3) USO O INCLUSION (USES):" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=21;fontStyle=5" parent="1" vertex="1">
          <mxGeometry x="26" y="1006" width="313" height="37" as="geometry" />
        </mxCell>
        <mxCell id="_BpPlqtfjkwMGcMm4Pci-35" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" parent="1" vertex="1">
          <mxGeometry x="37" y="1056" width="268.44" height="247" as="geometry" />
        </mxCell>
        <mxCell id="_BpPlqtfjkwMGcMm4Pci-37" value="Cuando un Caso de Uso solo es iniciado o interactua&amp;nbsp;&lt;div&gt;con 1 solo actor&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;es extends,&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;p&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;ero cuando dicho caso de uso interactua con 2 actores es uses&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=15;" parent="1" vertex="1">
          <mxGeometry x="346.44" y="1109" width="447" height="66" as="geometry" />
        </mxCell>
        <mxCell id="_BpPlqtfjkwMGcMm4Pci-38" value="4) HERENCIA:" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=21;fontStyle=5" parent="1" vertex="1">
          <mxGeometry x="47" y="1364" width="157" height="37" as="geometry" />
        </mxCell>
