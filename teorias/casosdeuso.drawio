        <mxCell id="_BpPlqtfjkwMGcMm4Pci-27" value="1) El Actor &quot;Miembro del club&quot; es quien incia el caso de uso" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=15;" parent="1" vertex="1">
