                <mxCell id="55" value="&lt;b&gt;Escenario 1: Solicitud exitosa&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;DADO&lt;/b&gt;&amp;nbsp;la capsula &quot;3&quot; con fecha 12/05/2026, donde la capsula esta disponible para &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;tal fecha y año del salto 1998 no riesgoso&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;CUANDO&lt;/b&gt;&amp;nbsp;el investigador autenticado selecciona la capsula &quot;3&quot;, fecha de &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;salto &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;12/05/2026, año 1998 y presiona &quot;solicitar turno&quot;&lt;/div&gt;&lt;div&gt;&lt;b style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;ENTONCES&lt;/b&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;&amp;nbsp;el sistema registrar la solicitud con exito, envia un mail al investigador &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;con la fecha y año ingresado, y un codigo de referencia a la reserva&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;" parent="1" vertex="1">
                    <mxGeometry x="52" y="2995" width="708" height="139" as="geometry"/>
                </mxCell>
                <mxCell id="56" value="&lt;b&gt;Escenario 2: Solicitud fallida por año riesgoso&lt;br&gt;&lt;/b&gt;&lt;b style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;DADO&lt;/b&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;&amp;nbsp;el año 1895 de alto riesgo&lt;/span&gt;&lt;div&gt;&lt;b style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;CUANDO&lt;/b&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;&amp;nbsp;el investigador autenticado selecciona la capsula &quot;a&quot;, fecha 20/03/2026,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;año 1895 y presiona &quot;solicitar turno&quot;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;b style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;ENTONCES&lt;/b&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;&amp;nbsp;el sistema muestra un mensaje de advertencia indicando &quot;destino&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;temporal clasificado como riesgoso. Selecciono otro año&quot;.&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;" parent="1" vertex="1">
                    <mxGeometry x="48" y="3144" width="708" height="139" as="geometry"/>
