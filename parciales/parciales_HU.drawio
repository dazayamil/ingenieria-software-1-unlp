                <mxCell id="13" value="&lt;b&gt;Escenario 1: Reserva exitosa&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;DADO&lt;/b&gt; una fecha actual 25/11/2025, una fecha de ingreso 30/11/2025, fecha de &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;egreso 05/12/2025 y un hotel &quot;WDhotels&quot; que pertenece a la cadena hotelera&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;CUANDO&lt;/b&gt; el usuario autenticado &quot;Juan Perez&quot;, ingresa la fecha de ingreso &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&quot;30/11/2025&quot;, fecha de egreso &quot;05/12/2025&quot;, hotel &quot;WDhotels&quot; y cantidad de &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;personas 4&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;ENTONCES&lt;/b&gt; el sistema registra la reserva, envia un correo electronico con el &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;codigo de reserva y un enlace para continuar con el pago&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;" parent="1" vertex="1">
                    <mxGeometry x="65" y="491" width="698" height="167" as="geometry"/>
                </mxCell>
                <mxCell id="17" value="&lt;b&gt;Escenario 2: Reserva fallida por superar el plazo a 90 dias&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;DADO&lt;/b&gt; una fecha actual 25/11/2025 y una fecha de ingreso 20/03/2026 (todos los &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;siguientes datos se ponen?) PREGUNTAR&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;CUANDO&lt;/b&gt; el usuario autenticado &quot;Juan Perez&quot;, ingresa la fecha de ingreso &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&quot;20/03/2026&quot;, fecha de egreso &quot;25/03/2026&quot;, hotel &quot;WDhotels&quot; y cantidad de &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;personas 4&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;ENTONCES&lt;/b&gt; el sistema informa un error por superar el plazo de 90 dias en base a &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;la fecha actual&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;" parent="1" vertex="1">
                    <mxGeometry x="69" y="684" width="698" height="167" as="geometry"/>
                </mxCell>
                <mxCell id="18" value="&lt;b&gt;Escenario 3: Reserva fallida por superar el plazo de estadia a 15 dias&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;DADO&lt;/b&gt; una fecha de ingreso 05/01/2026 y una fecha de egreso 25/01/2026 &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;(PREGUNTAR: hace falta poner la fecha actual)&amp;nbsp;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;CUANDO&lt;/b&gt; el usuario autenticado &quot;Juan Perez&quot;, ingresa la fecha de ingreso &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&quot;05/01/2026&quot;, fecha de egreso &quot;25/01/2026&quot;, hotel &quot;WDhotels&quot; y cantidad de &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;personas 4&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;ENTONCES&lt;/b&gt; el sistema informa un error por superar el plazo de estadia a 15 dias&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;" parent="1" vertex="1">
                    <mxGeometry x="69" y="869" width="698" height="167" as="geometry"/>
