                <mxCell id="24" value="&lt;b&gt;Escenario 1: Check in exitoso&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;DADO&lt;/b&gt;&amp;nbsp;un codigo de reserva valido &quot;253035&quot;, perteneciente a la fecha actual y en &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;el horario de las 11am&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;CUANDO&lt;/b&gt; el usuario autenticado &quot;Pedro Gomez&quot; ingresa el codigo de reserva &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&quot;253035&quot; y le da al boton &quot;confirmar check in&quot;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;ENTONCES&lt;/b&gt; el sistema registra el check in, informa la habitacion asignada, envia &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;un mensaje al conserje para guiar al usuario y otro mensaje a los botones para &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;que se hagan cargo de las valijas.&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;" parent="1" vertex="1">
                    <mxGeometry x="68" y="1490" width="708" height="167" as="geometry"/>
                </mxCell>
                <mxCell id="26" value="&lt;b&gt;Escenario 2: Check in fallido por realizar fuera del horario establecido&lt;/b&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;DADO&lt;/b&gt;&amp;nbsp;que son las 9am (PREGUNTAR, esta completo?)&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;CUANDO&lt;/b&gt; el usuario autenticado &quot;Pedro Gomez&quot; ingresa el codigo de reserva &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&quot;253035&quot; y le da al boton &quot;confirmar check in&quot;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;b&gt;ENTONCES&lt;/b&gt; el sistema informa que aun no se encuentran habilitados los ingresos &lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;al hotel&lt;br&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;" parent="1" vertex="1">
